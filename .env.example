# Monday Pipeline Brief — environment variables
# Copy to .env for local runs, or set as GitHub Actions secrets.
# Never commit real values.

# HubSpot Service Key (Bearer token, read-only scopes)
HUBSPOT_TOKEN=

# Email delivery — Resend (default)
RESEND_API_KEY=
# From address must be on a Resend-verified domain
BRIEF_FROM_EMAIL=DSN Brief <brief@yourdomain.com>
BRIEF_TO_EMAIL=isaacs@dsn.com

# Email delivery — Gmail SMTP fallback (used if RESEND_API_KEY is unset)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional: tune the staleness threshold (days)
STALE_DAYS=45

# Optional later: AI-drafted openers
ANTHROPIC_API_KEY=
